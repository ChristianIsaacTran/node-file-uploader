// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model File {
  id           Int     @id @default(autoincrement())
  fileLocation String
  fileFolder   Folders @relation(fields: [fileFolderId], references: [id])
  fileFolderId Int //foreign key for relation (references the id in Folders table)
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique @db.VarChar(255)
  password String    @db.VarChar()
  folders  Folders[] //users can have many folders, scalar field to define relation with Folders
}

// folders are associated with users with their user id
model Folders {
  id           Int    @id @default(autoincrement())
  folderRoute  String
  folderName   String 
  folderUser   User   @relation(fields: [folderUserId], references: [id]) //each folder will have a unique user id to show folder ownership
  folderUserId Int //foreign key for relation (references id from User table)
  files        File[] //folders can have many files
  parentFolder String 
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}
